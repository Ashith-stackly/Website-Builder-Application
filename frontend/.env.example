# ─────────────────────────────────────────────────────────────
# Frontend (Next.js) environment variables
# Copy to `.env.local` and adjust. All client-exposed vars must
# be prefixed with NEXT_PUBLIC_ (they are inlined at build time).
# ─────────────────────────────────────────────────────────────

# Base URL of the backend API (backend runs on :5000 by default)
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api

# Optional base path when hosting under a sub-path (leave empty for root)
NEXT_PUBLIC_BASE_PATH=

# Google OAuth client id (must match backend GOOGLE_CLIENT_ID)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# Razorpay checkout (client)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
# Base URL for the Razorpay dev API helper (see scripts/razorpay-api-server.mjs)
NEXT_PUBLIC_RAZORPAY_API_BASE=http://localhost:3001
# "true" to run Razorpay in demo mode (no live charges)
NEXT_PUBLIC_RAZORPAY_DEMO=true
