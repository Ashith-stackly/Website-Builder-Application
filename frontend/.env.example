# API Configuration
# The base URL for the backend API server. Defaults to http://localhost:5000/api in local dev.
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api

# Base Path Configuration
# Optional: Used when deploying to a subdirectory (e.g. GitHub Pages /Website-Builder-Application).
# Leave empty for root-level domain deployments.
NEXT_PUBLIC_BASE_PATH=

# Razorpay Checkout (Client-Side)
# Razorpay public key ID.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_Sx4RHrkl9mpz0s
# Base URL for the Razorpay dev API helper. Defaults to http://localhost:3001 in local dev.
NEXT_PUBLIC_RAZORPAY_API_BASE=http://localhost:3001
# "true" to run Razorpay in demo mode (no live charges, clicks approve mock UI), "false" for actual API integration.
NEXT_PUBLIC_RAZORPAY_DEMO=false

# Google OAuth
# Google client ID for user authentication via Google Accounts.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id

# E-commerce Storefront Configuration
# Optional: Custom workspace ID for default storefront landing page.
NEXT_PUBLIC_ECOMMERCE_WORKSPACE_ID=
