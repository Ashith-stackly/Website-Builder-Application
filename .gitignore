frontend/.next/
frontend/out/
frontend/build/
*.tsbuildinfo
frontend/next-env.d.ts

# ---- backend runtime artifacts ----
backend/uploads/
backend/storage/
backend/logs/
backend/*.log

# ---- testing / coverage ----
coverage/

# ---- editor / OS ----
.DS_Store
Thumbs.db
*.pem
.idea/
.vscode/


# ---- debug logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- misc ----
.vercel
