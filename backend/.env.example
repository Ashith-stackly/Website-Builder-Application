# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:5000/api
CORS_ORIGINS=http://localhost:3000
APP_DOMAIN=localhost
PUBLIC_APP_DOMAIN=localhost


# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1

# JWT
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-this-to-another-random-string
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth (optional — leave placeholder if not configured)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback


# GitHub OAuth (optional — not yet implemented)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Email / SMTP
# EMAIL_DELIVERY_MODE: 'smtp' for real emails, 'console' for dev (prints OTP to terminal)
EMAIL_DELIVERY_MODE=console
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Stackly
SMTP_FROM_EMAIL=
TEST_EMAIL_TO=


# SMS
# SMS_PROVIDER: 'mock' (dev), 'twilio', or 'textlocal'
SMS_PROVIDER=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TEXTLOCAL_API_KEY=
TEXTLOCAL_SENDER=

# Razorpay (Primary Payment)
PAYMENT_PRIMARY_PROVIDER=razorpay
RAZORPAY_MODE=test
RAZORPAY_KEY_ID=rzp_test_Sx4RHrkl9mpz0s
RAZORPAY_KEY_SECRET=JGQNY14J8H0Rs6RvoPe7LyOs

# E-commerce checkout totals are calculated server-side.
ECOMMERCE_TAX_RATE=0
ECOMMERCE_SHIPPING_COST=0
ECOMMERCE_WORKSPACE_ID=
SEED_STORE_USER_EMAIL=


# Stripe (Secondary — optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# AWS S3 (Publishing & Uploads)
AWS_S3_BUCKET=your-s3-bucket-name
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Email Domain Whitelist Configuration
EMAIL_DOMAIN_WHITELIST_ENABLED=false
EMAIL_DOMAIN_WHITELIST=gmail.com,yahoo.com,outlook.com,hotmail.com

# Password History Settings
PASSWORD_HISTORY_DEPTH=3

# AI Content Assistant (server-side only; never expose these values to the frontend)
# AI_PROVIDER: openai (production), mock (local smoke tests), disabled/none
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1-mini
IMAGE_PROVIDER=openai
OPENAI_IMAGE_MODEL=gpt-image-1
# Optional: use a compatible OpenAI endpoint in a self-hosted/enterprise setup.
OPENAI_API_BASE_URL=https://api.openai.com/v1
AI_REQUEST_TIMEOUT_MS=30000
AI_RATE_LIMIT_WINDOW_MS=60000
AI_TEXT_RATE_LIMIT_MAX=20
AI_IMAGE_RATE_LIMIT_MAX=6
AI_LAYOUT_RATE_LIMIT_MAX=30
